# CurveLens environment configuration.
# Copy to .env (gitignored) and fill in real values.

# EIA (Energy Information Administration) API key — required for weekly
# petroleum status data. Free key: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# FRED API key — required only by products with a configured public macro
# capability (currently Gold). Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Notes:
# - Telegram delivery is handled by the OpenClaw curvelens agent's own
#   integration, NOT by this project. No bot token or chat id belongs here or
#   anywhere in this repo (see AGENTS.md Safety Rules).
# - Catalyst extraction uses the `claude` CLI via your existing Claude Code
#   OAuth session — no API key is stored on disk for it.
