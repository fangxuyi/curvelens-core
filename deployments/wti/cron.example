# OpenClaw cron template for the CurveLens WTI deployment.
#
# This is intentionally an agent turn, not a plain system cron command:
# - the Python pipeline collects, normalizes, computes features, and formats
#   the daily brief + alert messages
# - the OpenClaw curvelens agent fetches the Akamai-protected CME bulletin,
#   runs the pipeline, and delivers the messages via its own Telegram integration
#
# A bare `python agent/run_pipeline.py` in system cron is NOT sufficient:
# nothing would fetch the CME bulletin (bot-protected) or deliver Telegram —
# both require the agent, per deployments/wti/AGENTS.md Runtime Model.
#
# Runs every 30 minutes in the T+1 early-morning retry window. Each firing uses
# the headed Playwright downloader to capture the CME "current" bulletin and
# read its internal date, then only processes it if that date is new
# (notify.py --is-new gate); a firing that finds an already-handled date stays
# silent, so repeated firings never duplicate Telegram sends.
# Ships --disabled with a telegram:YOUR_CHAT_ID placeholder — fill in the real
# chat id and enable deliberately. Do not commit a working chat id here.

openclaw cron add \
  --agent curvelens \
  --name "CurveLens daily brief" \
  --cron "*/30 2-6 * * 2-6" \
  --tz "America/New_York" \
  --session isolated \
  --message "From /path/to/curvelens-core, read AGENTS.md and deployments/wti/AGENTS.md and follow both exactly. Set CCVM_PRODUCT=wti and CCVM_DATA_DIR=/absolute/path/to/wti-data on every pipeline and notify command. This cron reruns every half hour across the early-morning window; never duplicate Telegram by using the freshness gate. Use the WTI headed Playwright downloader from the deployment runbook. If it fails, finish CME_PDF_UNAVAILABLE and send nothing. Parse its JSON with Python; use date as <pdf-date> and path as the saved PDF path. Run notify.py --is-new, then the pipeline only for a new date. On success prepare and list pending messages, deliver each text verbatim via Telegram, and ack each successful send. Never fabricate data or use --force-pdf without approval." \
  --model "openai/gpt-5.5" \
  --thinking low \
  --timeout-seconds 900 \
  --no-deliver \
  --disabled

# ── Event-calendar runs (D1) — same-day mini-runs, no bulletin needed ──
# Scheduled per knowledge/wti/calendar.yaml. Both stay silent unless the
# event is material (EIA: seasonal trigger confirms; COT: |WoW| ≥ 20k lots
# or 1y percentile ≥90/≤10). Ship --disabled; enable deliberately.

openclaw cron add \
  --agent curvelens \
  --name "CurveLens EIA flash" \
  --cron "35 10 * * 3" \
  --tz "America/New_York" \
  --session isolated \
  --message "From /path/to/curvelens-core, read AGENTS.md and deployments/wti/AGENTS.md. Set CCVM_PRODUCT=wti and CCVM_DATA_DIR=/absolute/path/to/wti-data, then run ccvm/.venv/bin/python agent/event_run.py --event eia. If the result is QUIET, NO_DATA, or ALREADY_HANDLED, finish silently. If FLASH_QUEUED, list pending messages and deliver only EIA_FLASH items verbatim via Telegram to telegram:YOUR_CHAT_ID, then ack each successful send. Parse JSON with Python, not jq." \
  --model "openai/gpt-5.5" \
  --thinking low \
  --timeout-seconds 600 \
  --no-deliver \
  --disabled

openclaw cron add \
  --agent curvelens \
  --name "CurveLens COT update" \
  --cron "35 15 * * 5" \
  --tz "America/New_York" \
  --session isolated \
  --message "From /path/to/curvelens-core, read AGENTS.md and deployments/wti/AGENTS.md. Set CCVM_PRODUCT=wti and CCVM_DATA_DIR=/absolute/path/to/wti-data, then run ccvm/.venv/bin/python agent/event_run.py --event cot. If the result is QUIET, NO_DATA, or ALREADY_HANDLED, finish silently. If UPDATE_QUEUED, list pending messages and deliver only COT_UPDATE items verbatim via Telegram to telegram:YOUR_CHAT_ID, then ack each successful send. Parse JSON with Python, not jq." \
  --model "openai/gpt-5.5" \
  --thinking low \
  --timeout-seconds 600 \
  --no-deliver \
  --disabled
