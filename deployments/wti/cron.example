# Disabled OpenClaw schedule template for CurveLens WTI daily analysis.
#
# This must trigger an isolated agent turn. A bare Python cron is unsupported
# because it cannot perform the approved CME bulletin acquisition or create the
# native QC, specialist, and synthesis sub-agents.
#
# Replace /path/to/curvelens-core and curvelens-wti before registration. Review
# the window and runtime cost, then obtain explicit approval before removing
# --disabled or enabling the resulting schedule. This template performs no
# delivery and contains no destination or credential.

openclaw cron add \
  --agent curvelens-wti \
  --name "CurveLens WTI daily analysis" \
  --cron "*/30 2-6 * * 2-6" \
  --tz "America/New_York" \
  --session isolated \
  --message 'From /path/to/curvelens-core, operate the CurveLens WTI deployment. Read AGENTS.md and deployments/wti/AGENTS.md and set CCVM_PRODUCT=wti on every runtime command. Acquire the exact current CME Section 63 bulletin with the approved headed-browser method, verify its internal trade date, and save it at the product-scoped required path. Then use $curvelens-daily-analysis to run WTI for that trade date. Resume existing workflow state; never use --restart, call the removed script-only daily entry point, invoke notify.py, or deliver anything. Finish silently if that trade date is already COMPLETE; otherwise report completion or the exact blocker.' \
  --timeout-seconds 1800 \
  --no-deliver \
  --disabled
